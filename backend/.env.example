# SyncVeil Backend - Environment Variables Template
# Copy this to .env for local development or configure in Render dashboard for production

# ============================================
# ENVIRONMENT
# ============================================
ENV=production
LOG_LEVEL=INFO

# ============================================
# DATABASE (REQUIRED for production)
# ============================================
# Render: Auto-set via DATABASE_URL from PostgreSQL service
# Local Dev: Use PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/syncveil

# ============================================
# JWT AUTHENTICATION (REQUIRED)
# ============================================
# Render: Auto-generated by Render (32+ characters)
# Local Dev: Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-32-character-minimum-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================
# VAULT ENCRYPTION (REQUIRED)
# ============================================
# Render: Auto-generated by Render (32+ characters)
# Local Dev: Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
VAULT_ENCRYPTION_KEY=change-me-to-a-32-character-minimum-secret-here
VAULT_STORAGE_DIR=/tmp/vault_storage

# ============================================
# CORS CONFIGURATION (REQUIRED for production)
# ============================================
CORS_ORIGINS=https://syncveil.software,https://www.syncveil.software,https://syncveil-website.onrender.com
FRONTEND_URL=https://syncveil.software

# ============================================
# EMAIL SERVICE (OPTIONAL)
# ============================================
# If EMAIL_ENABLED=false, email verification is skipped
EMAIL_ENABLED=false
BREVO_API_KEY=
SMTP_FROM=
EMAIL_FROM_NAME=SyncVeil

# ============================================
# EMAIL VERIFICATION (OPTIONAL)
# ============================================
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_VERIFICATION_EXPIRE_HOURS=24

# ============================================
# OAUTH PROVIDERS (REQUIRED for social login)
# ============================================
GOOGLE_CLIENT_ID=
MICROSOFT_CLIENT_ID=
APPLE_CLIENT_ID=
OAUTH_REDIRECT_BASE=http://localhost:5173/auth/callback

# ============================================
# OTP CONFIGURATION
# ============================================
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=3

# ============================================
# PASSWORD HASHING (Argon2)
# ============================================
# Memory cost: 65536 KB (~64MB) - appropriate for most servers
# Time cost: 2 - fast enough for login (tuned for Render free tier)
# Parallelism: 1 - single thread for Render compatibility
PASSWORD_HASH_TIME_COST=2
PASSWORD_HASH_MEMORY_COST=65536
PASSWORD_HASH_PARALLELISM=1

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_OTP=3/minute
RATE_LIMIT_SIGNUP=2/minute

# ============================================
# ADMIN (Optional)
# ============================================
# Leave empty for production (no default admin account)
INITIAL_ADMIN_EMAIL=

# ============================================
# LOGGING
# ============================================
LOG_FILE=logs/syncveil.log

# ============================================
# SECURITY ENGINE
# ============================================
SECURITY_CHALLENGE_THRESHOLD=60
SECURITY_CRITICAL_THRESHOLD=85
SECURITY_EVENTS_DAYS=7

# ============================================
# REDIS (OPTIONAL - for advanced rate limiting)
# ============================================
# Leave empty if not using Redis
REDIS_URL=

# ============================================
# SECURITY / TRANSPORT
# ============================================
TLS_ENFORCE=true
CSRF_COOKIE_NAME=syncveil_csrf
REFRESH_COOKIE_NAME=syncveil_refresh
RATE_LIMIT_DEFAULT=120/minute
